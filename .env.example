# Telegram: create a bot via @BotFather -> token
TELEGRAM_BOT_TOKEN=

# Shared unlock code for members (≥12 chars). Rotate if leaked. Not your Google/Telegram password.
BOT_PASSCODE=

# Comma-separated Telegram numeric user IDs for admins (logistics desk).
# Get your ID from @userinfobot or similar.
ADMIN_TELEGRAM_IDS=123456789,987654321

# Google Sheet: create a sheet, share it with the service account email (Editor).
GOOGLE_SHEET_ID=

# Google auth: use a file path (local) OR paste JSON in env (e.g. Render) — not both required.
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Optional: comma-separated CCA names → users tap a button instead of typing CCA.
# Example: CCA_OPTIONS=Drama,Choir,Media Club
# Leave empty to ask "What CCA?" as free text.
CCA_OPTIONS=

# Session unlock lifetime in minutes (after inactivity, user must re-enter passcode).
SESSION_TTL_MINUTES=30
